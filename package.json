{
  "name": "media-universe",
  "version": "1.0.0",
  "type": "module",
  "description": "The Ultimate Multi-Source Media Desktop Application.",
  "author": "Antigravity",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "nodemon --watch server --ext ts --exec ts-node server/index.ts",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc server/index.ts --outDir server-dist --esModuleInterop --skipLibCheck --ignoreConfig",
    "build": "npm run build:client && npm run build:server",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "discord-rpc": "^4.0.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "puppeteer": "^25.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/discord-rpc": "^4.0.11",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
